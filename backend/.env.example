# PostgreSQL Connection Strings (Neon DB or Local Postgres)
NEON_HISTORY_DSN="postgresql://user:password@hostname/dbname?sslmode=require"
NEON_DB_DSN="postgresql://user:password@hostname/dbname?sslmode=require"
NEON_PRODUCTS_DSN="postgresql://user:password@hostname/dbname?sslmode=require"
NEON_CARTS_DSN="postgresql://user:password@hostname/dbname?sslmode=require"
NEON_ANALYTICS_DSN="postgresql://user:password@hostname/dbname?sslmode=require"

# Optional Gemini API key for Chatbot integrations
GEMINI_API_KEY="your_google_gemini_key_here"

# Application Settings
FLASK_ENV="development"
FLASK_APP="app.py"
PORT=5000
